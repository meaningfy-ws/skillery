[mypy]
# Strict-ish static typing. Config in this dedicated root file (decision D2).
python_version = <<PYTHON_VERSION>>
mypy_path = .
warn_unused_configs = True
warn_unused_ignores = True
warn_return_any = True
warn_unreachable = True
implicit_reexport = False
check_untyped_defs = True
no_implicit_optional = True
pretty = True

# No-src layout: the package sits at the repo root, so namespace discovery is flat.
explicit_package_bases = True
namespace_packages = True

# Prefer per-module overrides (below) for individual missing stubs. Flip this to
# True only if a hard dependency ships no py.typed and has no stubs at all.
# ignore_missing_imports = True

# Tests may use loosely-typed fixtures and parametrisation. `make typecheck` scopes
# mypy to the package only, so this override is an example — uncomment it (and add
# `tests` to the typecheck target) if you decide to type-check tests too.
# [mypy-tests.*]
# disallow_untyped_defs = False

# ---------------------------------------------------------------------------
# Per-module suppressions for third-party typing limitations.
# Add narrowly-scoped overrides here instead of a blanket ignore.
# ---------------------------------------------------------------------------
# Example: a third-party client whose async methods return `Awaitable[T] | T`
# unions that mypy cannot narrow through `await`.
# [mypy-<<PACKAGE>>.commons.adapters.some_client]
# disable_error_code = misc, no-any-return
