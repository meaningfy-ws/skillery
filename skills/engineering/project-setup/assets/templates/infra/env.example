# Environment template for <<PROJECT_NAME>>  (renders to infra/.env.example)
# ============================================================================
# Copy to infra/.env and fill in real values:  cp infra/.env.example infra/.env
# The Makefile docker targets pass --env-file infra/.env explicitly (D11).
#
# LAYERED ENV convention:
#   - infra/.env.example   committed; placeholders only, NO real secrets.
#   - infra/.env.common    (optional) committed; non-secret values shared
#                          across environments (ports, hostnames, feature flags).
#   - infra/.env           real, developer-local; gitignored — NEVER commit.
#   - .secrets.example     committed template for CI/`act` secrets (tokens);
#                          the real .secrets is gitignored.
# Rule of thumb: if a value would be safe in a public PR, it may live in a
# committed file; anything sensitive belongs only in the gitignored .env.

# --- Application ------------------------------------------------------------
APP_NAME="<<PROJECT_NAME>>"
APP_ENV=development
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# --- Datastore: PostgreSQL --------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app
POSTGRES_PORT=5432
DATABASE_URL="postgresql://app:changeme@localhost:5432/app"

# --- Datastore: MongoDB (uncomment if used) ---------------------------------
# MONGO_USER=app
# MONGO_PASSWORD=changeme
# MONGO_PORT=27017
# MONGO_URI="mongodb://app:changeme@localhost:27017"
# MONGO_DATABASE_NAME=app

# --- Cache / broker: Redis (uncomment if used) ------------------------------
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=changeme
# REDIS_URL="redis://localhost:6379/0"

# --- Development -------------------------------------------------------------
SEED_DB=false  # Set to 'true' to seed the DB on container startup (dev only).

# --- Observability / OpenTelemetry (disabled by default) --------------------
TRACING_ENABLED=false
OTEL_SERVICE_NAME=<<PROJECT_SLUG>>
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
