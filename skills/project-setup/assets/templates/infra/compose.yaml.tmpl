# Docker Compose — local development for <<PROJECT_NAME>>
# ============================================================================
# Run via the Makefile docker targets (they pass --env-file infra/.env, D11):
#   make up        # docker compose up -d
#   make watch     # live-sync source into the container (compose `watch`)
#   make logs      # follow logs
#   make down      # stop
#
# No-src layout: the build context is the repo root and the Dockerfile lives at
# infra/docker/Dockerfile. The shared app config is factored into the
# `x-app-common` anchor so several services can reuse it.

x-app-env: &app-env
  PYTHONDONTWRITEBYTECODE: 1
  PYTHONUNBUFFERED: 1
  # Point the app at the datastore service below (uncomment the matching one).
  # DATABASE_URL: postgresql://${POSTGRES_USER:-app}:${POSTGRES_PASSWORD:-app}@postgres:5432/${POSTGRES_DB:-app}
  # MONGO_URI: mongodb://${MONGO_USER:-app}:${MONGO_PASSWORD:-app}@mongo:27017
  # REDIS_URL: redis://redis:6379/0

x-app-common: &app-common
  build:
    context: ../..
    dockerfile: infra/docker/Dockerfile
    args:
      ENVIRONMENT: development
  env_file:
    - .env
  environment:
    <<: *app-env
  restart: unless-stopped
  develop:
    watch:
      - action: sync
        path: ../../<<PACKAGE>>
        target: /app/<<PACKAGE>>
      - action: rebuild
        path: ../../pyproject.toml
      - action: rebuild
        path: ../../poetry.lock
  networks:
    - <<PROJECT_SLUG>>-local

services:
  app:
    <<: *app-common
    container_name: "<<PROJECT_SLUG>>-app"
    ports:
      - "${APP_PORT:-8000}:8000"
    healthcheck:
      test: ["CMD-SHELL", "python -c 'import urllib.request; urllib.request.urlopen(\"http://localhost:8000/health\")' || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
    # Uncomment when a datastore service is enabled below.
    # depends_on:
    #   postgres:
    #     condition: service_healthy

  # --------------------------------------------------------------------------
  # Datastore — pick ONE (or more) by uncommenting. Defaults to Postgres.
  # --------------------------------------------------------------------------
  postgres:
    image: postgres:16-alpine
    container_name: "<<PROJECT_SLUG>>-postgres"
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-app}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-app}
      POSTGRES_DB: ${POSTGRES_DB:-app}
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-app}"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - <<PROJECT_SLUG>>-local

