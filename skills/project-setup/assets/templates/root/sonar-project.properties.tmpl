# SonarCloud configuration for <<PROJECT_NAME>>
# =============================================
# Project: https://sonarcloud.io/project/overview?id=meaningfy-ws_<<PROJECT_SLUG>>

sonar.projectKey=meaningfy-ws_<<PROJECT_SLUG>>
sonar.organization=meaningfy-ws

# Source and test paths (no-src layout: the top-level package is the source root).
sonar.sources=<<PACKAGE>>/
sonar.tests=tests/
sonar.python.version=<<PYTHON_VERSION>>

# Coverage and test reports (produced by `make test`).
sonar.python.coverage.reportPaths=coverage.xml
sonar.python.xunit.reportPath=test-results.xml

# Exclusions
sonar.coverage.exclusions=tests/**/*
sonar.cpd.exclusions=tests/**/*
sonar.exclusions=docs/**/*,*.md,infra/**/*
