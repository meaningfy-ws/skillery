# coverage.py configuration — renders to .coveragerc at the repo root.
# No-src layout: measure the top-level package directly.
[run]
branch = True
source = <<PACKAGE>>
omit = */__init__.py

[report]
fail_under = 80
show_missing = true
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    ^\s+\.\.\.$
    def __repr__
    raise NotImplementedError
