schema: meaningfy

# Project context — injected (wrapped in <context>) into every artifact's instructions.
# This is OpenSpec's native project-context sink. The durable truth is openspec/specs/;
# this string is the orientation index. If a generated index is ever wanted, regenerate it
# deterministically into this field (like codegen, with a CI sync-check) — do NOT hand-curate
# a parallel MEMORY.md.
context: |
  Repo: <<PROJECT_NAME>> (<<PROJECT_SLUG>>).
  Architecture: cosmic-python layering (domain, adapters, services, entrypoints);
  innermost layer is `domain`. Enforced by .importlinter (`make check-architecture`).
  Top-level package: <<PACKAGE>> (no /src). Default branch: <<DEFAULT_BRANCH>>.
  Commits: Conventional Commits (imperative, no trailing punctuation).
  Artifact vocabulary: EPIC ≡ proposal.md (Shape-Up work shape);
  PLAN ≡ design.md + tasks.md (clarity gate scores the pair ≥9/10);
  normative requirements ≡ specs/ deltas (RFC-2119 SHALL + Given/When/Then, no EARS).

# Per-artifact rules — THIN by design. Only the 3 hard rules; rich per-artifact rules are
# deferred. Additive to the schema's built-in instructions.
rules:
  proposal:
    - The EPIC MUST state an Appetite and a No-gos section (an EPIC without no-gos is unshaped).
  specs:
    - Use RFC-2119 SHALL/MUST; every requirement MUST have at least one #### Scenario (WHEN/THEN). No EARS.
  tasks:
    - The PLAN MUST cite its parent EPIC id on the first line (golden thread — cite your parent).
