{{!--
  Minimal branding header for the Antora default UI.
  Replace the brand text/logo with your project's, and keep the Lunr search box wired in.
--}}
<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item" href="{{{or site.url (or siteRootUrl siteRootPath)}}}">{{site.title}}</a>
      <div class="navbar-item search hide-for-print">
        {{#if env.SITE_SEARCH_PROVIDER}}
        <div id="search-field" class="field">
          <input id="search-input" type="text" placeholder="Search the docs"{{#if page.home}} autofocus{{/if}}>
        </div>
        {{/if}}
      </div>
    </div>
  </nav>
</header>
